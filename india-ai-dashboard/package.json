    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/postcss": "^4.3.2",
    "ai": "^6.0.230",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "11.18.2",
    "lucide-react": "0.468.0",
    "next": "16.2.9",
    "radix-ui": "^1.6.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
