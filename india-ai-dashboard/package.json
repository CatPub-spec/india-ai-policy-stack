{
  "name": "india-ai-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "verify:dashboard": "node ../dashboard-tools/verify-dashboard.mjs http://127.0.0.1:3000",
    "ingest:excel": "node ../dashboard-tools/sync-dashboard-data.mjs",
